<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml"
      xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <title>Order Confirmed — #{{orderNumber}}</title>
  <!--[if mso]>
  <noscript>
    <xml><o:OfficeDocumentSettings>
      <o:PixelsPerInch>96</o:PixelsPerInch>
    </o:OfficeDocumentSettings></xml>
  </noscript>
  <![endif]-->
  <style type="text/css">
    body, table, td, a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
    table, td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
    img { -ms-interpolation-mode:bicubic; border:0; height:auto; line-height:100%;
          outline:none; text-decoration:none; }
    body { margin:0 !important; padding:0 !important; width:100% !important; }
    /* Responsive styles */
    @media only screen and (max-width:620px) {
      .email-container { width:100% !important; max-width:none !important; }
      .stack-column { display:block !important; width:100% !important; }
      .mobile-padding { padding-left:16px !important; padding-right:16px !important; }
    }
  </style>
</head>
<body style="margin:0; padding:0; background-color:{{colors.bodyBg}}; width:100%;">

<!-- ============================================================
     Outer wrapper - Full width
     ============================================================ -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
       style="background-color:{{colors.bodyBg}};">
  <tr>
    <td align="center" style="padding:24px 16px;">

      <!-- Responsive container -->
      <table role="presentation" class="email-container" width="100%" cellpadding="0"
             cellspacing="0" border="0"
             style="width:100%; margin:0 auto;
                    background-color:{{colors.containerBg}};
                    box-shadow:0 1px 4px rgba(0,0,0,0.12);">

        <!-- ── HEADER ─────────────────────────────────────────── -->
        <tr><td>{{> header}}</td></tr>

        <!-- ── HERO: Confirmation message ─────────────────────── -->
        <tr>
          <td style="background-color:{{colors.containerBg}}; padding:36px 32px 32px 32px; text-align:center; border-bottom:1px solid {{colors.cardBorder}};">
            <!-- Checkmark circle -->
            <div style="display:inline-block; width:52px; height:52px;
                        background-color:#DC2626; border-radius:50%;
                        font-family:Arial,Helvetica,sans-serif; font-size:28px;
                        color:#FFFFFF; line-height:52px; text-align:center;
                        margin-bottom:16px;">&#10003;</div>
            <div style="font-family:Arial,Helvetica,sans-serif; font-size:26px;
                        font-weight:700; color:{{colors.textColor}}; letter-spacing:0.5px;
                        margin-bottom:8px;">
              Your Order Is Confirmed!
            </div>
            <div style="font-family:Arial,Helvetica,sans-serif; font-size:15px;
                        color:{{colors.textMuted}}; margin-bottom:16px;">
              Hi {{customerFirstName}}, thanks for shopping with JDM Tokyo Motorsports.
            </div>
            <!-- Order number badge -->
            <table role="presentation" align="center" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="background-color:#DC2626; border-radius:2px;
                           padding:8px 24px;">
                  <span style="font-family:Arial,Helvetica,sans-serif; font-size:14px;
                               font-weight:700; color:#FFFFFF; letter-spacing:2px;
                               text-transform:uppercase;">
                    Order #{{orderNumber}}
                  </span>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ── ORDER ITEMS TABLE ───────────────────────────────── -->
        <tr>
          <td style="padding:32px 32px 0 32px; background-color:{{colors.containerBg}};">
            <p style="font-family:Arial,Helvetica,sans-serif; font-size:14px; font-weight:700;
                      color:{{colors.textColor}}; text-transform:uppercase; letter-spacing:1px;
                      margin:0 0 16px 0; padding-bottom:10px;
                      border-bottom:2px solid {{colors.titleBorder}};">
              Order Summary
            </p>

            <!-- Table header -->
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr style="background-color:{{colors.accentColor}};">
                <td style="padding:10px 12px; font-family:Arial,Helvetica,sans-serif;
                           font-size:11px; font-weight:700; color:#FFFFFF;
                           text-transform:uppercase; letter-spacing:0.5px; width:40%;">
                  Product
                </td>
                <td style="padding:10px 8px; font-family:Arial,Helvetica,sans-serif;
                           font-size:11px; font-weight:700; color:#FFFFFF;
                           text-transform:uppercase; letter-spacing:0.5px; width:20%;">
                  SKU
                </td>
                <td style="padding:10px 8px; font-family:Arial,Helvetica,sans-serif;
                           font-size:11px; font-weight:700; color:#FFFFFF;
                           text-transform:uppercase; letter-spacing:0.5px; width:10%;
                           text-align:center;">
                  Qty
                </td>
                <td style="padding:10px 12px; font-family:Arial,Helvetica,sans-serif;
                           font-size:11px; font-weight:700; color:#FFFFFF;
                           text-transform:uppercase; letter-spacing:0.5px; width:30%;
                           text-align:right;">
                  Price
                </td>
              </tr>

              <!-- Line items loop -->
              {{#each items}}
              <tr style="background-color:{{#if @even}}{{../colors.rowEvenBg}}{{else}}{{../colors.rowOddBg}}{{/if}};">
                <td style="padding:12px 12px; font-family:Arial,Helvetica,sans-serif;
                           font-size:13px; color:{{../colors.textColor}}; vertical-align:top;
                           border-bottom:1px solid {{../colors.rowBorder}};">
                  {{this.title}}
                </td>
                <td style="padding:12px 8px; font-family:Arial,Helvetica,sans-serif;
                           font-size:12px; color:{{../colors.textMuted}}; vertical-align:top;
                           border-bottom:1px solid {{../colors.rowBorder}};">
                  {{this.sku}}
                </td>
                <td style="padding:12px 8px; font-family:Arial,Helvetica,sans-serif;
                           font-size:13px; color:{{../colors.textColor}}; vertical-align:top;
                           text-align:center; border-bottom:1px solid {{../colors.rowBorder}};">
                  {{this.quantity}}
                </td>
                <td style="padding:12px 12px; font-family:Arial,Helvetica,sans-serif;
                           font-size:13px; color:{{../colors.textColor}}; vertical-align:top;
                           text-align:right; border-bottom:1px solid {{../colors.rowBorder}};">
                  {{formatPrice this.lineTotal}}
                </td>
              </tr>
              {{/each}}

            </table>
          </td>
        </tr>

        <!-- ── TOTALS ──────────────────────────────────────────── -->
        <tr>
          <td style="padding:0 32px 32px 32px; background-color:{{colors.containerBg}};">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <!-- Subtotal -->
              <tr>
                <td style="padding:10px 12px 4px 12px; font-family:Arial,Helvetica,sans-serif;
                           font-size:13px; color:{{colors.textMuted}}; text-align:right;">
                  Subtotal
                </td>
                <td style="padding:10px 12px 4px 0; font-family:Arial,Helvetica,sans-serif;
                           font-size:13px; color:{{colors.textColor}}; text-align:right; width:110px;">
                  {{formatPrice subtotal}}
                </td>
              </tr>

              <!-- Shipping -->
              <tr>
                <td style="padding:4px 12px; font-family:Arial,Helvetica,sans-serif;
                           font-size:13px; color:{{colors.textMuted}}; text-align:right;">
                  Shipping ({{shippingMethod}})
                </td>
                <td style="padding:4px 12px 4px 0; font-family:Arial,Helvetica,sans-serif;
                           font-size:13px; color:{{colors.textColor}}; text-align:right;">
                  {{formatPrice shippingCost}}
                </td>
              </tr>

              {{#if discount}}
              <!-- Discount -->
              <tr>
                <td style="padding:4px 12px; font-family:Arial,Helvetica,sans-serif;
                           font-size:13px; color:{{colors.accentColor}}; text-align:right;">
                  Discount {{#if discountCode}}({{discountCode}}){{/if}}
                </td>
                <td style="padding:4px 12px 4px 0; font-family:Arial,Helvetica,sans-serif;
                           font-size:13px; color:{{colors.accentColor}}; text-align:right;">
                  &minus;{{formatPrice discount}}
                </td>
              </tr>
              {{/if}}

              <!-- Divider -->
              <tr>
                <td colspan="2" style="padding:8px 0;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                         border="0">
                    <tr>
                      <td style="height:2px; background-color:{{colors.dividerColor}}; font-size:0;
                                 line-height:0;">&nbsp;</td>
                    </tr>
                  </table>
                </td>
              </tr>

              <!-- Grand total -->
              <tr>
                <td style="padding:8px 12px 4px 12px; font-family:Arial,Helvetica,sans-serif;
                           font-size:15px; font-weight:700; color:{{colors.textColor}}; text-align:right;">
                  Total
                </td>
                <td style="padding:8px 12px 4px 0; font-family:Arial,Helvetica,sans-serif;
                           font-size:15px; font-weight:700; color:{{colors.accentColor}}; text-align:right;">
                  {{formatPrice total}}
                </td>
              </tr>

            </table>
          </td>
        </tr>

        <!-- ── SHIPPING ADDRESS ────────────────────────────────── -->
        <tr>
          <td style="padding:0 32px 32px 32px; background-color:{{colors.containerBg}};">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                   style="border:1px solid {{colors.cardBorder}}; background-color:{{colors.cardBg}}; border-radius:2px;">
              <tr>
                <td style="padding:16px 20px;">
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:11px;
                             font-weight:700; color:{{colors.textMuted}}; text-transform:uppercase;
                             letter-spacing:1px; margin:0 0 10px 0;">
                    Shipping Address
                  </p>
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:14px;
                             color:{{colors.textColor}}; line-height:1.6; margin:0;">
                    <strong>{{shippingAddress.name}}</strong><br>
                    {{shippingAddress.line1}}<br>
                    {{#if shippingAddress.line2}}{{shippingAddress.line2}}<br>{{/if}}
                    {{shippingAddress.city}}, {{shippingAddress.state}} {{shippingAddress.zip}}<br>
                    {{shippingAddress.country}}
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        {{#if billingAddress}}
        <!-- ── BILLING ADDRESS ─────────────────────────────────── -->
        <tr>
          <td style="padding:0 32px 32px 32px; background-color:{{colors.containerBg}};">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                   style="border:1px solid {{colors.cardBorder}}; background-color:{{colors.cardBg}}; border-radius:2px;">
              <tr>
                <td style="padding:16px 20px;">
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:11px;
                             font-weight:700; color:{{colors.textMuted}}; text-transform:uppercase;
                             letter-spacing:1px; margin:0 0 10px 0;">
                    Billing Address
                  </p>
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:14px;
                             color:{{colors.textColor}}; line-height:1.6; margin:0;">
                    <strong>{{billingAddress.name}}</strong><br>
                    {{billingAddress.line1}}<br>
                    {{#if billingAddress.line2}}{{billingAddress.line2}}<br>{{/if}}
                    {{billingAddress.city}}, {{billingAddress.state}} {{billingAddress.zip}}<br>
                    {{billingAddress.country}}
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        {{/if}}

        <!-- ── WHAT HAPPENS NEXT ───────────────────────────────── -->
        <tr>
          <td style="padding:0 32px 32px 32px; background-color:{{colors.containerBg}};">
            <p style="font-family:Arial,Helvetica,sans-serif; font-size:14px; font-weight:700;
                      color:{{colors.textColor}}; text-transform:uppercase; letter-spacing:1px;
                      margin:0 0 16px 0; padding-bottom:10px;
                      border-bottom:2px solid {{colors.titleBorder}};">
              What Happens Next?
            </p>

            <!-- Step 1 -->
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                   style="margin-bottom:14px;">
              <tr>
                <td style="width:36px; vertical-align:top; padding-top:2px;">
                  <div style="width:28px; height:28px; background-color:{{colors.accentColor}};
                              border-radius:50%; font-family:Arial,Helvetica,sans-serif;
                              font-size:13px; font-weight:700; color:#FFFFFF;
                              text-align:center; line-height:28px;">1</div>
                </td>
                <td style="vertical-align:top; padding-left:10px;">
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:14px;
                             font-weight:700; color:{{colors.textColor}}; margin:0 0 2px 0;">
                    Invoice on its way
                  </p>
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:13px;
                             color:{{colors.textMuted}}; margin:0; line-height:1.5;">
                    You'll receive a full invoice by email shortly.
                  </p>
                </td>
              </tr>
            </table>

            <!-- Step 2 -->
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                   style="margin-bottom:14px;">
              <tr>
                <td style="width:36px; vertical-align:top; padding-top:2px;">
                  <div style="width:28px; height:28px; background-color:{{colors.accentColor}};
                              border-radius:50%; font-family:Arial,Helvetica,sans-serif;
                              font-size:13px; font-weight:700; color:#FFFFFF;
                              text-align:center; line-height:28px;">2</div>
                </td>
                <td style="vertical-align:top; padding-left:10px;">
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:14px;
                             font-weight:700; color:{{colors.textColor}}; margin:0 0 2px 0;">
                    Order preparation
                  </p>
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:13px;
                             color:{{colors.textMuted}}; margin:0; line-height:1.5;">
                    We'll carefully pick, pack, and prepare your order for shipment.
                  </p>
                </td>
              </tr>
            </table>

            <!-- Step 3 -->
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="width:36px; vertical-align:top; padding-top:2px;">
                  <div style="width:28px; height:28px; background-color:{{colors.accentColor}};
                              border-radius:50%; font-family:Arial,Helvetica,sans-serif;
                              font-size:13px; font-weight:700; color:#FFFFFF;
                              text-align:center; line-height:28px;">3</div>
                </td>
                <td style="vertical-align:top; padding-left:10px;">
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:14px;
                             font-weight:700; color:{{colors.textColor}}; margin:0 0 2px 0;">
                    Tracking info sent
                  </p>
                  <p style="font-family:Arial,Helvetica,sans-serif; font-size:13px;
                             color:{{colors.textMuted}}; margin:0; line-height:1.5;">
                    Once your order ships you'll receive a tracking number by email so you
                    can follow it every step of the way.
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ── REFUND DISCLAIMER ───────────────────────────────── -->
        <tr><td>{{> refund-disclaimer}}</td></tr>

        <!-- ── FOOTER ─────────────────────────────────────────── -->
        <tr><td>{{> footer}}</td></tr>

      </table>
      <!-- /container -->

    </td>
  </tr>
</table>
<!-- /outer wrapper -->

</body>
</html>
